<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{% block title %}Cyna{% endblock %}</title>

    {# Bootstrap 5 (CDN) #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root{
            --cyna-bg1:#060b1a;
            --cyna-bg2:#0a1230;
            --cyna-card: rgba(255,255,255,.06);
            --cyna-border: rgba(255,255,255,.10);
            --cyna-text: rgba(255,255,255,.86);
            --cyna-muted: rgba(255,255,255,.60);
        }

        body{
            min-height:100vh;
            color: var(--cyna-text);
            background: radial-gradient(1200px 600px at 20% 0%, #1a3b4a 0%, transparent 60%),
                        radial-gradient(1200px 600px at 100% 20%, #2d2355 0%, transparent 55%),
                        linear-gradient(180deg, var(--cyna-bg1), var(--cyna-bg2));
        }

        .glass {
            background: rgba(255,255,255,.06);
            border: 1px solid var(--cyna-border);
            backdrop-filter: blur(10px);
        }

        .brand-dot{
            width:34px;height:34px;border-radius:12px;
            background: linear-gradient(135deg, #7cf, #95f);
            display:inline-block;
        }

        .hero{
            margin-top: 2rem;
            padding: 2.2rem 0 1rem;
        }

        .hero h1{
            letter-spacing: .5px;
            font-weight: 800;
        }

        .muted{ color: var(--cyna-muted); }

        .card-cyna{
            border-radius: 18px;
            overflow: hidden;
            border: 1px solid var(--cyna-border);
            background: var(--cyna-card);
        }

        .card-img-top{
            height: 170px;
            object-fit: cover;
        }

        .chip{
            position:absolute;
            left:14px;
            bottom:14px;
            padding:.35rem .7rem;
            border-radius: 999px;
            font-weight: 600;
            font-size: .9rem;
            color: white;
            background: rgba(0,0,0,.45);
            border: 1px solid rgba(255,255,255,.20);
        }

        footer{
            border-top: 1px solid rgba(255,255,255,.08);
            margin-top: 3rem;
            padding: 1.5rem 0;
            color: var(--cyna-muted);
        }
        a{ color: inherit; }
        a:hover{ color: white; }

    /* Champ de recherche - correction contraste */
.navbar input::placeholder,
input.form-control::placeholder {
    color: rgba(255,255,255,.55);
}

.navbar input,
input.form-control {
    color: white;
}

.navbar input:focus,
input.form-control:focus {
    background-color: transparent;
    color: white;
    box-shadow: none;
}

    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

<nav class="container mt-3">
    <div class="glass rounded-4 px-3 py-2 d-flex align-items-center gap-3">
        <span class="brand-dot"></span>
        <strong class="me-2">CYNA</strong>

        <form class="flex-grow-1">
            <div class="input-group">
                <span class="input-group-text bg-transparent text-white-50 border-0">🔎</span>
                <input class="form-control bg-transparent text-white border-0"
                       placeholder="Rechercher un produit..."
                       aria-label="Rechercher">
            </div>
        </form>

        <a class="btn btn-outline-light rounded-pill px-3" href="#">
            🛒 <span class="ms-1">Panier</span>
        </a>
    </div>
</nav>

<main class="container">
    {% block body %}{% endblock %}
</main>

<footer class="container">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>© {{ "now"|date("Y") }} Cyna</div>
        <div class="d-flex gap-3">
            <a href="#">Mentions légales</a>
            <a href="#">CGU</a>
            <a href="#">Contact</a>
            <a href="#">Réseaux</a>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
