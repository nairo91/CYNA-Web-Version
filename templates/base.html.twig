<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}CYNA{% endblock %}</title>

    {# Bootstrap 5 (CDN) #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root{
            --bg0:#050916;
            --bg1:#070b1c;
            --bg2:#0a1230;
            --card: rgba(255,255,255,.06);
            --card2: rgba(255,255,255,.08);
            --line: rgba(255,255,255,.10);
            --text: rgba(255,255,255,.86);
            --muted: rgba(255,255,255,.62);
            --accent: #2f7bff;
            --accent2:#5bc0ff;
        }

        body{
            min-height: 100vh;
            background:
                radial-gradient(900px 400px at 20% 10%, rgba(47,123,255,.18), transparent 60%),
                radial-gradient(900px 400px at 90% 20%, rgba(91,192,255,.12), transparent 55%),
                linear-gradient(180deg, var(--bg0), var(--bg1) 40%, var(--bg2));
            color: var(--text);
        }

        .glass{
            background: rgba(255,255,255,.06);
            border: 1px solid rgba(255,255,255,.10);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }

        .brand-dot{
            width: 32px; height: 32px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--accent2), #8a5bff);
            display:inline-block;
        }

        .navbar .nav-link{ color: var(--muted) !important; }
        .navbar .nav-link:hover{ color: white !important; }

        /* ✅ Correction lisibilité champ recherche (texte + placeholder) */
        .navbar .form-control{
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.12);
            color: rgba(255,255,255,.92);
        }
        .navbar .form-control::placeholder{ color: rgba(255,255,255,.55); }
        .navbar .form-control:focus{
            background: rgba(255,255,255,.10);
            border-color: rgba(91,192,255,.45);
            box-shadow: 0 0 0 .25rem rgba(47,123,255,.15);
            color: white;
        }

        .btn-accent{
            background: linear-gradient(135deg, var(--accent), #1f56ff);
            border: none;
        }
        .btn-accent:hover{ filter: brightness(1.06); }

        .section-title{ font-weight: 800; letter-spacing: .2px; }
        .section-sub{ color: var(--muted); }

        .cyna-card{
            background: var(--card);
            border: 1px solid var(--line);
            border-radius: 18px;
        }
        .cyna-card:hover{
            background: var(--card2);
            transform: translateY(-2px);
            transition: .2s ease;
        }

        footer{
            border-top: 1px solid rgba(255,255,255,.10);
            color: rgba(255,255,255,.70);
        }
        footer a{ color: rgba(255,255,255,.70); text-decoration: none; }
        footer a:hover{ color: white; }

        .navbar-toggler { border-color: rgba(255,255,255,.25); }
        .navbar-toggler-icon { filter: invert(1); }

    </style>

    {% block stylesheets %}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>
        <style>
            .swiper-container {
                width: 100%;
                padding-top: 50px;
                padding-bottom: 50px;
                overflow: hidden;
            }
            .swiper-slide {
                background-position: center;
                background-size: cover;
                background-color: var(--bg0); /* Fond opaque noir/bleu foncé pour cacher le texte derrière */
                width: 55%; 
                max-width: 800px;
                border-radius: 18px;
                opacity: 0.6; /* Assombrit les côtés sans faire de filtre bizarre */
                transition: all 0.4s ease;
                /* Optional glow effect for modern aesthetics */
                box-shadow: 0 15px 35px rgba(0,0,0,0.5), 0 0 20px rgba(47,123,255,0.2);
            }
            .swiper-slide-active {
                opacity: 1; /* Le centre redevient bien éclairé */
                background-color: var(--bg1); /* Légèrement plus clair que le fond pour détacher la carte active */
                box-shadow: 0 15px 35px rgba(0,0,0,0.5), 0 0 40px rgba(47,123,255,0.4);
            }
            .swiper-pagination-bullet {
                background: rgba(255,255,255,0.5);
            }
            .swiper-pagination-bullet-active {
                background: var(--accent);
            }
            .swiper-button-next, .swiper-button-prev {
                color: var(--accent2);
                background: rgba(0,0,0,0.3);
                width: 50px; height: 50px;
                border-radius: 50%;
                backdrop-filter: blur(5px);
            }
            .swiper-button-next::after, .swiper-button-prev::after {
                font-size: 20px;
            }
        </style>
    {% endblock %}
</head>

<body>
<header class="container-fluid px-0">
    <nav class="navbar navbar-expand-lg glass py-3">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2 text-white fw-bold" href="{{ path('app_home') }}">
                <span class="brand-dot"></span>
                <span>CYNA</span>
            </a>

            <button class="navbar-toggler text-white" type="button" data-bs-toggle="collapse" data-bs-target="#navCyna">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navCyna">
                <form class="d-flex mx-lg-4 my-3 my-lg-0 flex-grow-1" role="search">
                    <input class="form-control rounded-pill px-4" type="search" placeholder="Rechercher un service..." aria-label="Search">
                </form>

                <ul class="navbar-nav ms-lg-auto align-items-lg-center gap-lg-3">
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#services">Services</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#tarifs">Tarifs</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#contact">Contact</a></li>
                    <li class="nav-item ms-lg-2">
                        <a class="btn btn-sm btn-outline-light rounded-pill px-3" href="{{ path('app_cart') }}">Panier</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<main>
    {% block body %}{% endblock %}
</main>

<footer class="mt-5 py-5">
  <div class="container">
    <div class="row g-4 align-items-start">
      <div class="col-md-6">
        <div class="fw-bold text-white mb-1">CYNA</div>
        <div class="text-white-50">Plateforme SaaS de cybersécurité</div>
        <div class="text-white-50 small mt-2">© {{ "now"|date("Y") }} CYNA</div>
      </div>

      <div class="col-md-6 d-flex flex-column flex-md-row justify-content-md-end gap-3">
        <a href="#">Mentions légales</a>
        <a href="#">CGU</a>
        <a href="#contact">Contact</a>
        <a href="#" aria-label="Réseaux sociaux">Réseaux</a>
      </div>
    </div>
  </div>
</footer>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var swiper = new Swiper('.mySwiper', {
                effect: 'coverflow',
                grabCursor: true,
                centeredSlides: true,
                slidesPerView: 'auto',
                loop: true,
                loopedSlides: 3, /* Force Duplication pour n'avoir aucun vide lors du défilement */
                coverflowEffect: {
                    rotate: 0, /* Pas de rotation sur les côtés pour qu'ils prennent moins de largeur */
                    stretch: 120, /* Rapproche fortement les cartes sur les côtés du centre */
                    depth: 150, /* Réduit l'effet de recul pour s'assurer de les garder dans l'écran */
                    modifier: 1, /* Facteur d'application des effets (1 = normal) */
                    slideShadows: true, /* Active les vraies ombres directionnelles 3D de Swiper */
                },
                pagination: {
                    el: '.swiper-pagination',
                    clickable: true,
                    type: 'custom',
                    renderCustom: function (swiper, current, total) {
                        var html = '';
                        // current va de 1 à 6 (puisqu'on a 6 slides). On le ramène à 0, 1 ou 2.
                        var activeIndex = (current - 1) % 3;
                        for (var i = 0; i < 3; i++) {
                            var activeClass = i === activeIndex ? ' swiper-pagination-bullet-active' : '';
                            html += '<span class="swiper-pagination-bullet' + activeClass + ' custom-bullet" data-index="' + i + '" style="cursor:pointer; margin: 0 5px; display:inline-block;"></span>';
                        }
                        return html;
                    }
                },
                navigation: {
                    nextEl: '.swiper-button-next',
                    prevEl: '.swiper-button-prev',
                },
                autoplay: {
                    delay: 4000,
                    disableOnInteraction: false,
                }
            });

            // Permet de cliquer sur les 3 points virtuels pour naviguer
            document.querySelector('.swiper-pagination').addEventListener('click', function(e) {
                if (e.target.classList.contains('custom-bullet')) {
                    var index = parseInt(e.target.getAttribute('data-index'));
                    swiper.slideToLoop(index);
                }
            });
        });
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>
