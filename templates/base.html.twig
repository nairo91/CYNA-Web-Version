<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}CYNA{% endblock %}</title>

    {# Bootstrap 5 CDN (simple, rapide, accepté en projet scolaire) #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #0f172a;
            color: #e5e7eb;
        }

        .navbar {
            background-color: #020617;
        }

        .hero {
            padding: 6rem 1rem;
            background: linear-gradient(135deg, #020617, #020617);
            text-align: center;
        }

        footer {
            background-color: #020617;
            padding: 2rem 0;
            margin-top: 4rem;
            text-align: center;
            color: #94a3b8;
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>

<body>

<header>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">CYNA</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#">Services</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Tarifs</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Contact</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<main>
    {% block body %}{% endblock %}
</main>

<footer>
    <div class="container">
        <p class="mb-1">© {{ "now"|date("Y") }} CYNA</p>
        <small>Plateforme SaaS de cybersécurité</small>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}

</body>
</html>
